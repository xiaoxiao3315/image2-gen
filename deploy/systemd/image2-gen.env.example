# Copy to /etc/image2-gen/image2-gen.env, replace every secret placeholder,
# set owner root:image2gen and mode 0640. Never commit the populated file.

# Cloud A: provider generation credentials (required).
IMAGE_API_KEY=<set-with-a-secret-value>
IMAGE_API_BASE_URL=https://your-image-api-endpoint/v1
IMAGE_API_PROXY=
IMAGE_MODEL=gpt-image-2
IMAGE_SOURCE_SIZE=1536x1024
IMAGE_API_CONNECT_TIMEOUT_SECONDS=20
IMAGE_API_TIMEOUT_SECONDS=300
IMAGE_API_MAX_ATTEMPTS=3

# Current direct public origin (no trailing slash). Keep this as a placeholder in Git.
PUBLIC_BASE_URL=http://your-cloud-public-ip
IMAGE_SERVICE_DATA=/var/lib/image2-gen
IMAGE_GENERATION_WORKERS=3
IMAGE_FIXED_QUALITY=low

# Use two distinct random secrets. The worker token must be at least 32 chars.
IMAGE_SERVICE_TOKEN=<set-with-a-random-leader-token>
IMAGE_UPSCALE_WORKER_TOKEN=<set-with-a-distinct-random-worker-token-at-least-32-chars>
IMAGE_UPSCALE_LEASE_SECONDS=600
IMAGE_UPSCALE_MAX_ATTEMPTS=3
IMAGE_UPSCALE_MAX_UPLOAD_BYTES=52428800

# Optional verified fixed per-image provider price. Leave blank if unverified.
IMAGE_API_COST_CNY_FIXED=
