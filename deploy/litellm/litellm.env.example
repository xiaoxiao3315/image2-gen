# Copy to /etc/image2-gen/litellm.env on the server, owned by root with mode
# 0600. Never commit or copy the populated file back into the repository.
# Every secret below must be distinct. Use URL-safe characters for the database
# password, or percent-encode it in DATABASE_URL.

POSTGRES_PASSWORD=
DATABASE_URL=
LITELLM_MASTER_KEY=
LITELLM_SALT_KEY=
IMAGE_LITELLM_BACKEND_TOKEN=

# LiteLLM spend is denominated in USD. Set the billable amount for one delivered
# image, not the upstream CNY cost. Integration tests verify that n multiplies it.
IMAGE_COST_USD_PER_IMAGE=0.01
