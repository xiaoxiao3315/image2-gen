# Never paste a real key or service token into this file. Set secrets in the
# process/user environment. IMAGE_API_KEY (or OPENAI_API_KEY) is required on Cloud A.
IMAGE_API_BASE_URL=https://your-image-api-endpoint/v1
IMAGE_API_PROXY=
IMAGE_MODEL=gpt-image-2
IMAGE_SOURCE_SIZE=1536x1024
IMAGE_API_CONNECT_TIMEOUT_SECONDS=20
IMAGE_API_TIMEOUT_SECONDS=300
IMAGE_API_MAX_ATTEMPTS=3

# Cloud A: public API, source generation, queue and final image hosting.
IMAGE_SERVICE_DATA=service-data
IMAGE_GENERATION_WORKERS=3
IMAGE_FIXED_QUALITY=low
PUBLIC_BASE_URL=http://your-cloud-public-ip
IMAGE_UPSCALE_LEASE_SECONDS=600
IMAGE_UPSCALE_MAX_UPLOAD_BYTES=52428800
# IMAGE_SERVICE_TOKEN must be supplied only through the cloud process environment.
# IMAGE_UPSCALE_WORKER_TOKEN must be a different secret of at least 32 characters.

# Local B: outbound-only Windows Real-ESRGAN worker. It does not need IMAGE_API_KEY.
IMAGE_CLOUD_BASE_URL=http://your-cloud-public-ip
IMAGE_UPSCALE_WORKER_ID=
IMAGE_UPSCALE_WORKER_CONCURRENCY=3
IMAGE_UPSCALE_POLL_SECONDS=4
IMAGE_UPSCALE_WORK_ROOT=remote-worker-data
# 0 disables tiling to avoid visible seams; use 512/256 only when VRAM is tight.
REALESRGAN_TILE_SIZE=0
# Set the same IMAGE_UPSCALE_WORKER_TOKEN through the Windows user environment.

# Optional verified channel prices. Leave unset until confirmed from billing.
# IMAGE_API_COST_CNY_FIXED=
# IMAGE_API_COST_CNY_LOW=
# IMAGE_API_COST_CNY_MEDIUM=
# IMAGE_API_COST_CNY_HIGH=

# Local electricity estimate only.
GPU_POWER_WATTS=175
ELECTRICITY_CNY_PER_KWH=0.60
